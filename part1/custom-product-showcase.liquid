    JAVASCRIPT
═══════════════════════════════════════ {%- endcomment -%}
<script>
(function () {
  'use strict';

  // ── Cart dialog ────────────────────────────────────────────────
  window.pscOpenDialog = function (btn) {
    var sectionId = btn.closest('[id^="section-"]').id.replace('section-', '');
    var dialog    = document.getElementById('psc-dialog-' + sectionId);
    var nameEl    = document.getElementById('psc-dialog-product-' + sectionId);
    if (!dialog) return;
    nameEl.textContent = btn.dataset.productTitle || 'Item';
    dialog.showModal();

    // Auto-close after 6 s if user doesn't interact
    clearTimeout(dialog._autoClose);
    dialog._autoClose = setTimeout(function () {
      pscCloseDialog(sectionId);
    }, 6000);
  };

  window.pscCloseDialog = function (sectionId) {
    var dialog = document.getElementById('psc-dialog-' + sectionId);
    if (dialog && dialog.open) dialog.close();
  };

  // Close on backdrop click
  document.addEventListener('click', function (e) {
    if (e.target && e.target.nodeName === 'DIALOG') {
      var sId = e.target.id.replace('psc-dialog-', '');
      pscCloseDialog(sId);
    }
  });

  // ── Reviews carousel ───────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[id^="psc-reviews-"]').forEach(function (section) {
      var sectionId  = section.id.replace('psc-reviews-', '');
      var track      = document.getElementById('psc-track-'  + sectionId);
      var dotsWrap   = document.getElementById('psc-dots-'   + sectionId);
      if (!track || !dotsWrap) return;

      var slides     = Array.from(track.children);
      var total      = slides.length;
      var current    = 0;
      var perView    = getPerView();
      var maxIndex   = Math.max(0, total - perView);
      var autoTimer;

      function getPerView() {
        if (window.innerWidth >= 1100) return Math.min(3, total);
        if (window.innerWidth >= 768)  return Math.min(2, total);
        return 1;
      }

      function buildDots() {
        dotsWrap.innerHTML = '';
        var dotCount = maxIndex + 1;
        for (var i = 0; i <= maxIndex; i++) {
          var d = document.createElement('button');
          d.className = 'psc__dot' + (i === current ? ' psc__dot--active' : '');
          d.setAttribute('aria-label', 'Go to review ' + (i + 1));
          d.setAttribute('role', 'tab');
          d.dataset.index = i;
          d.addEventListener('click', function () { goTo(parseInt(this.dataset.index)); });
          dotsWrap.appendChild(d);
        }
      }

      function updateDots() {
        Array.from(dotsWrap.children).forEach(function (d, i) {
          d.classList.toggle('psc__dot--active', i === current);
        });
      }

      function goTo(index) {
        current = Math.max(0, Math.min(index, maxIndex));
        var slideWidth = slides[0] ? slides[0].getBoundingClientRect().width : 0;
        track.style.transform = 'translateX(-' + (current * slideWidth) + 'px)';
        updateDots();
        resetAuto();
      }

      window['pscSlide'] = window['pscSlide'] || {};
      window.pscSlide = function (sid, dir) {
        // Called from inline onclick — route to correct instance
        if (sid === sectionId) {
          goTo(current + dir);
        }
      };

      function resetAuto() {
        clearInterval(autoTimer);
        autoTimer = setInterval(function () {
          goTo(current >= maxIndex ? 0 : current + 1);
        }, 5000);
      }

      // Recalculate on resize
      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          perView  = getPerView();
          maxIndex = Math.max(0, total - perView);
          current  = Math.min(current, maxIndex);
          buildDots();
          goTo(current);
        }, 200);
      });

      // Touch / swipe support
      var touchStartX = 0;
      track.addEventListener('touchstart', function (e) {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      track.addEventListener('touchend', function (e) {
        var delta = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(delta) > 40) goTo(current + (delta > 0 ? 1 : -1));
      });

      // Init
      buildDots();
      resetAuto();
    });
  });
})();
</script>


